# Grok (xAI) API key — used for AI lyric sync, mood/genre/BPM detection,
# theme + palette + font + animation + background recommendations.
# Get a key at https://console.x.ai
VITE_GROK_API_KEY=your_grok_api_key_here
VITE_GROK_API_BASE_URL=https://api.x.ai/v1

# Optional: override the default Grok model used for text/JSON tasks
VITE_GROK_MODEL=grok-2-latest
