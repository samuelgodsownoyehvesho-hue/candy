    "@react-three/fiber": "^8.17.7",
    "@react-three/drei": "^9.111.3",
    "gsap": "^3.12.5",
    "wavesurfer.js": "^7.8.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "clsx": "^2.1.1",
    "zustand": "^4.5.5",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.167.1",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
